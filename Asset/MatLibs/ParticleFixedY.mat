{
    "name": "Particle",
    "techniques": {
        "default": {
            "shaders": {
                "vs": "Shaders/ParticleFixedY_v.glsl",
                "fs": "Shaders/Particle_f.glsl"
            },
            "cullFace": false,
            "DepthTestEnable": true,
            "DepthWriteEnable": false,
            "BlendEnable": true,
            "SrcBlendFactor": "SrcAlpha",
            "DstBlendFactor": "One"
        }
    },
    "property": {
        "attributes": [
            {
                "name": "TU_camPos",
                "type": "semantic_CameraPos"
            },
            {
                "name": "TU_camDir",
                "type": "semantic_CameraDir"
            },
            {
                "name": "TU_roughness",
                "type": "float",
                "default": 5.0
            },
            {
                "name": "TU_depthBias",
                "type": "float",
                "default": 0.0
            },
            {
                "name": "TU_color",
                "type": "vec4",
                "default": [
                    1.0,
                    1.0,
                    1.0,
                    1.0
                ]
            }
        ],
        "maps": [
            [
                "DiffuseMap",
                0
            ]
        ]
    }
}
