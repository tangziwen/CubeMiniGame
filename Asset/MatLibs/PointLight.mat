{
    "name": "PointLight",
    "techniques": {
        "default": {
            "shaders": {
                "vs": "Shaders/PointLight_v.glsl",
                "fs": "Shaders/PointLight_f.glsl"
            },
            "CullMode": "front",
            "DepthTestEnable": false,
            "DepthWriteEnable": false,
            "BlendEnable": true,
            "SrcBlendFactor": "One",
            "DstBlendFactor": "One"
        }
    },
    "property": {
        "attributes": [
            {
                "name": "TU_roughness",
                "type": "float",
                "default": 5.0
            },
            {
                "name": "TU_winSize",
                "type": "semantic_WinSize"
            },
            {
                "name": "TU_camPos",
                "type": "semantic_CameraPos"
            },
            {
                "name": "TU_viewProjectInverted",
                "type": "semantic_ViewProjectInverted"
            }
        ],
        "maps": []
    }
}
