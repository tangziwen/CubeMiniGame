{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc-common",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "environment": {
        "CC": null,
        "CXX": null
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CUBEENGINE_USE_VULKAN": "ON",
        "CUBEENGINE_USE_OPENGL": "ON",
        "CUBEENGINE_USE_PYTHON_SCRIPTING": "ON",
        "CUBEENGINE_USE_FMOD": "ON",
        "CUBEENGINE_USE_SOLOUD": "ON",
        "CUBEENGINE_BUILD_BULLET_FROM_SOURCE": "ON"
      }
    },
    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC x64",
      "inherits": "windows-msvc-common",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;RelWithDebInfo"
      }
    },
    {
      "name": "ninja-multi",
      "displayName": "Ninja Multi-Config",
      "inherits": "windows-msvc-common",
      "generator": "Ninja Multi-Config",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;RelWithDebInfo",
        "CMAKE_C_FLAGS": "/DWIN32 /D_WINDOWS /W3",
        "CMAKE_CXX_FLAGS": "/DWIN32 /D_WINDOWS /W3 /GR /EHsc",
        "CMAKE_C_FLAGS_DEBUG": "/Zi /Ob0 /Od /RTC1",
        "CMAKE_CXX_FLAGS_DEBUG": "/Zi /Ob0 /Od /RTC1",
        "CMAKE_C_FLAGS_RELWITHDEBINFO": "/Zi /O2 /Ob2 /Oi /Ot /DNDEBUG",
        "CMAKE_CXX_FLAGS_RELWITHDEBINFO": "/Zi /O2 /Ob2 /Oi /Ot /DNDEBUG",
        "CMAKE_EXE_LINKER_FLAGS_RELWITHDEBINFO": "/debug /INCREMENTAL",
        "CMAKE_SHARED_LINKER_FLAGS_RELWITHDEBINFO": "/debug /INCREMENTAL",
        "CMAKE_MODULE_LINKER_FLAGS_RELWITHDEBINFO": "/debug /INCREMENTAL"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "configurePreset": "windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "windows-msvc-relwithdebinfo",
      "displayName": "Windows MSVC RelWithDebInfo",
      "configurePreset": "windows-msvc",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug",
      "configurePreset": "ninja-multi",
      "configuration": "Debug"
    },
    {
      "name": "ninja-relwithdebinfo",
      "displayName": "Ninja RelWithDebInfo",
      "configurePreset": "ninja-multi",
      "configuration": "RelWithDebInfo"
    }
  ]
}
